local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local localPlayer = Players.LocalPlayer

local RemoteEvents = ReplicatedStorage:WaitForChild("RemoteEvents")
local RemoteFireMelee = RemoteEvents:WaitForChild("RemoteFireMelee")
local RemoteCritMelee = RemoteEvents:WaitForChild("RemoteCritMelee")
local RemoteMelee = RemoteEvents:WaitForChild("RemoteMelee")

-- Load the effect manager for explosions
local EffectManager = require(ReplicatedStorage:WaitForChild("ModuleScripts"):WaitForChild("EffectManager"))

local CharacterManager = require(ReplicatedStorage:WaitForChild("ModuleScripts"):WaitForChild("CharacterManager"))

local backpack = localPlayer:WaitForChild("Backpack")
local character = localPlayer.Character or localPlayer.CharacterAdded:Wait()

local AURA_RANGE = 35
local USE_OLD_CRIT = true -- true = "Melee" string 100% crit, false = tool-based crit

-- Explosion configuration per weapon
local WEAPON_EXPLOSIONS = {
    ["Knife"] = {type = "Fire", intensity = 6},
    ["Baseball Bat"] = {type = "Flare", intensity = 8},
    ["Military Axe"] = {type = "Stun", intensity = 10},
    ["Katana"] = {type = "Fire", intensity = 9},
    ["Energy Sword"] = {type = "Flare", intensity = 12},
    ["Alpha Energy Sword"] = {type = "Flare", intensity = 14},
    ["Shovel"] = {type = "Stun", intensity = 11},
    ["Axe"] = {type = "Stun", intensity = 10}
}

local function enableRunGun()
    local perks = localPlayer:WaitForChild("PlayerPerks")
    if perks:FindFirstChild("RunGun") then
        perks.RunGun:Destroy()
    end
    local runGun = Instance.new("NumberValue")
    runGun.Name = "RunGun"
    runGun.Value = 1
    runGun.Parent = perks
end

enableRunGun()

local function keepEnergyFull(tool)
    task.spawn(function()
        while tool and tool.Parent do
            task.wait(0.05)
            local cv = tool:FindFirstChild("CurrentValues")
            if cv then
                local energy = cv:FindFirstChild("Energy")
                local maxEnergy = cv:FindFirstChild("MaxEnergy")
                if energy and maxEnergy then
                    energy.Value = maxEnergy.Value
                end
            end
        end
    end)
end

local function getAttackSpeed()
    local ok, speed = pcall(function()
        return CharacterManager:GetValue("MeleeAttackSpeed", localPlayer)
    end)
    if ok and speed and speed > 0 then
        return 60 / speed
    end
    return 0.12
end

local lastFire = {}

local function canFire(weaponName)
    local now = tick()
    local cooldown = getAttackSpeed()
    if not lastFire[weaponName] or (now - lastFire[weaponName]) >= cooldown then
        lastFire[weaponName] = now
        return true
    end
    return false
end

local function isAlive()
    local char = localPlayer.Character
    if not char then return false end
    local humanoid = char:FindFirstChild("Humanoid")
    return humanoid and humanoid.Health > 0
end

local function fireCrit(tool)
    if USE_OLD_CRIT then
        RemoteCritMelee:FireServer("Melee", true, {["Momentum"] = 100})
    else
        RemoteCritMelee:FireServer(tool, true, {["Momentum"] = 100})
    end
end

local function fireRemoteMelee(tool)
    local char = localPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local cf = hrp.CFrame
    RemoteMelee:FireServer(localPlayer, tool, 0, cf, cf)
end

local function getHitPart(zombie)
    return zombie:FindFirstChild("Head")
        or zombie:FindFirstChild("HumanoidRootPart")
        or zombie:FindFirstChild("Torso")
        or zombie.PrimaryPart
end

local function getInRange()
    local targets = {}
    local char = localPlayer.Character
    local myHrp = char and char:FindFirstChild("HumanoidRootPart")
    if not myHrp then return targets end

    local myPos = myHrp.Position

    for _, v in pairs(workspace.Zombies:GetChildren()) do
        local zombieHumanoid = v:FindFirstChild("Zombie") or v:FindFirstChildOfClass("Humanoid")
        if zombieHumanoid and zombieHumanoid.Health > 0 then
            local tPart = getHitPart(v)
            if tPart then
                local dist = (tPart.Position - myPos).Magnitude
                if dist <= AURA_RANGE then
                    table.insert(targets, {instance = v, distance = dist})
                end
            end
        end
    end

    table.sort(targets, function(a, b)
        return a.distance < b.distance
    end)

    local finalTargets = {}
    for _, t in ipairs(targets) do
        table.insert(finalTargets, t.instance)
    end

    return finalTargets
end

local function buildHits(targets)
    local hits = {}
    for _, zombie in ipairs(targets) do
        local part = getHitPart(zombie)
        if part then
            table.insert(hits, {[1] = part, [2] = {}})
        end
    end
    return hits
end

local function buildHitsEnergySword(targets)
    local hits = {}
    for _, zombie in ipairs(targets) do
        local part = getHitPart(zombie)
        if part then
            table.insert(hits, {
                [1] = part,
                [2] = {["ActiveAnimation"] = "Right", ["AltDamage"] = true}
            })
        end
    end
    return hits
end

local function createExplosionsAtTargets(weaponName, targets)
    if not targets or #targets == 0 then return end
    
    local explosionConfig = WEAPON_EXPLOSIONS[weaponName]
    if not explosionConfig then return end
    
    for _, zombie in ipairs(targets) do
        local part = getHitPart(zombie)
        if part then
            task.spawn(function()
                pcall(function()
                    EffectManager:CreateExplosion(
                        part.Position,
                        explosionConfig.intensity,
                        explosionConfig.type
                    )
                end)
            end)
        end
    end
end

local function doFire(weaponName, targets)
    local char = localPlayer.Character
    local bp = localPlayer.Backpack
    if not char or not bp then return end

    if weaponName == "Knife" then
        local hits = buildHits(targets)
        if #hits == 0 then return end
        local knifeTool = char:FindFirstChild("Knife") or bp:FindFirstChild("Knife")
        fireRemoteMelee(knifeTool or "Melee")
        fireCrit("Melee")
        task.wait(0.05)
        RemoteFireMelee:FireServer("Melee", hits, {["Momentum"] = 100, ["Critical"] = true})
        createExplosionsAtTargets(weaponName, targets)

    elseif weaponName == "Baseball Bat" then
        local tool = char:FindFirstChild("Baseball Bat") or bp:FindFirstChild("Baseball Bat")
        local hits = buildHits(targets)
        if #hits == 0 then return end
        fireRemoteMelee(tool)
        fireCrit(tool)
        RemoteFireMelee:FireServer(tool, hits, {["ActiveAnimation"] = "Left", ["Critical"] = true, ["Momentum"] = 100})
        createExplosionsAtTargets(weaponName, targets)

    elseif weaponName == "Military Axe" then
        local tool = char:FindFirstChild("Military Axe") or bp:FindFirstChild("Military Axe")
        local hits = buildHits(targets)
        if #hits == 0 then return end
        fireRemoteMelee(tool)
        fireCrit(tool)
        RemoteFireMelee:FireServer(tool, hits, {["ActiveAnimation"] = "Right", ["Critical"] = true, ["Momentum"] = 100})
        createExplosionsAtTargets(weaponName, targets)

    elseif weaponName == "Katana" then
        local tool = char:FindFirstChild("Katana") or bp:FindFirstChild("Katana")
        local hits = buildHits(targets)
        if #hits == 0 then return end
        fireRemoteMelee(tool)
        fireCrit(tool)
        RemoteFireMelee:FireServer(tool, hits, {["ActiveAnimation"] = "Left", ["Critical"] = true, ["Momentum"] = 100})
        createExplosionsAtTargets(weaponName, targets)

    elseif weaponName == "Energy Sword" then
        local tool = char:FindFirstChild("Energy Sword") or bp:FindFirstChild("Energy Sword")
        local hits = buildHitsEnergySword(targets)
        if #hits == 0 then return end
        fireRemoteMelee(tool)
        fireCrit(tool)
        RemoteFireMelee:FireServer(tool, hits, {["ActiveAnimation"] = "Right", ["Critical"] = true})
        createExplosionsAtTargets(weaponName, targets)

    elseif weaponName == "Alpha Energy Sword" then
        local tool = char:FindFirstChild("Alpha Energy Sword") or bp:FindFirstChild("Alpha Energy Sword")
        local hits = buildHitsEnergySword(targets)
        if #hits == 0 then return end
        fireRemoteMelee(tool)
        fireCrit(tool)
        RemoteFireMelee:FireServer(tool, hits, {["ActiveAnimation"] = "Right", ["Critical"] = true, ["Momentum"] = 100})
        createExplosionsAtTargets(weaponName, targets)

    elseif weaponName == "Shovel" then
        local tool = char:FindFirstChild("Shovel") or bp:FindFirstChild("Shovel")
        local hits = buildHits(targets)
        if #hits == 0 then return end
        fireRemoteMelee(tool)
        fireCrit(tool)
        RemoteFireMelee:FireServer(tool, hits, {["ActiveAnimation"] = "Over", ["Critical"] = true, ["Momentum"] = 100})
        createExplosionsAtTargets(weaponName, targets)

    elseif weaponName == "Axe" then
        local tool = char:FindFirstChild("Axe") or bp:FindFirstChild("Axe")
        local hits = buildHits(targets)
        if #hits == 0 then return end
        fireRemoteMelee(tool)
        fireCrit(tool)
        RemoteFireMelee:FireServer(tool, hits, {["ActiveAnimation"] = "Right", ["Critical"] = true, ["Momentum"] = 100})
        createExplosionsAtTargets(weaponName, targets)
    end
end

local activeAuras = {}
local specialWeaponNames = {
    "Baseball Bat", "Military Axe", "Katana",
    "Energy Sword", "Alpha Energy Sword", "Shovel", "Axe"
}

local function hasAnySpecialWeapon(char, bp)
    for _, name in ipairs(specialWeaponNames) do
        if char:FindFirstChild(name) or bp:FindFirstChild(name) then return true end
    end
    return false
end

local function startCritLoop(weaponName)
    task.spawn(function()
        while activeAuras[weaponName] do
            task.wait(0.05)
            if not isAlive() then continue end
            pcall(function()
                local char = localPlayer.Character
                local bp = localPlayer.Backpack
                if not char or not bp then return end
                local tool = char:FindFirstChild(weaponName)
                    or bp:FindFirstChild(weaponName)
                    or char:FindFirstChildOfClass("Tool")
                if USE_OLD_CRIT then
                    RemoteCritMelee:FireServer("Melee", true, {["Momentum"] = 100})
                else
                    RemoteCritMelee:FireServer(tool or "Melee", true, {["Momentum"] = 100})
                end
            end)
        end
    end)
end

local function startAura(weaponName)
    if activeAuras[weaponName] then return end
    activeAuras[weaponName] = true

    startCritLoop(weaponName)

    if weaponName == "Energy Sword" or weaponName == "Alpha Energy Sword" then
        local char = localPlayer.Character
        local bp = localPlayer.Backpack
        local tool = char and (char:FindFirstChild(weaponName) or bp:FindFirstChild(weaponName))
        if tool then keepEnergyFull(tool) end
    end

    task.spawn(function()
        while activeAuras[weaponName] do
            task.wait(0.01)
            if not isAlive() then continue end

            local targets = getInRange()
            if #targets > 0 and canFire(weaponName) then
                task.spawn(function()
                    pcall(doFire, weaponName, targets)
                end)
            end
        end
    end)
end

local function stopAura(weaponName)
    activeAuras[weaponName] = nil
end

local function updateKnifeAura(char, bp)
    if hasAnySpecialWeapon(char, bp) then
        stopAura("Knife")
    else
        startAura("Knife")
    end
end

local function onToolAdded(tool)
    local name = tool.Name
    if name == "Energy Sword" or name == "Alpha Energy Sword" then
        keepEnergyFull(tool)
    end
    for _, wName in ipairs(specialWeaponNames) do
        if name == wName then
            startAura(name)
            stopAura("Knife")
            return
        end
    end
end

local function onToolRemoved(tool)
    local name = tool.Name
    for _, wName in ipairs(specialWeaponNames) do
        if name == wName then
            task.wait()
            local char = localPlayer.Character
            local bp = localPlayer.Backpack
            if not ((char and char:FindFirstChild(name)) or bp:FindFirstChild(name)) then
                stopAura(name)
            end
            updateKnifeAura(char, bp)
            return
        end
    end
end

local function setupListeners(char)
    character = char
    char.ChildAdded:Connect(onToolAdded)
    char.ChildRemoved:Connect(onToolRemoved)
    backpack.ChildAdded:Connect(onToolAdded)
    backpack.ChildRemoved:Connect(onToolRemoved)

    char:WaitForChild("Humanoid").Died:Connect(function()
        for name in pairs(activeAuras) do stopAura(name) end
    end)

    for _, name in ipairs(specialWeaponNames) do
        local tool = char:FindFirstChild(name) or backpack:FindFirstChild(name)
        if tool then
            if name == "Energy Sword" or name == "Alpha Energy Sword" then
                keepEnergyFull(tool)
            end
            startAura(name)
        end
    end
    updateKnifeAura(char, backpack)
end

localPlayer.CharacterAdded:Connect(function(newChar)
    for name in pairs(activeAuras) do stopAura(name) end
    enableRunGun()
    task.wait(1)
    setupListeners(newChar)
end)

setupListeners(character)