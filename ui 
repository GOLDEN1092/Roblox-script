local energyBossThread  = nil
local bossConnection    = nil
local currentBoss       = nil

-- ========== BOSS LOOPS ==========
local function deadeyeBossLoop()
    while mainRunning and currentBoss and currentBoss.Parent do
        useConsumableIfOwned("Deadeye Drink")  -- cooldown guard deduplicates vs night loop
        task.wait(20)
    end
end

local function energyBossLoop()
    while mainRunning and currentBoss and currentBoss.Parent do
        useConsumableIfOwned("Energy Drink")
        task.wait(8)
    end
end

local function onBossAdded(bossInstance)
    if not mainRunning then return end
    if bossInstance.Name ~= "Boss" then return end
    if currentBoss and currentBoss.Parent then return end
    currentBoss = bossInstance

    -- UI: switch to BOSS status + update title
    setStatus("BOSS")
    titleLabel.Text = "⚡ BOSS"

    print("[Boss] Boss detected – Deadeye (20s) & Energy (8s) loops starting")
    if deadeyeBossThread then task.cancel(deadeyeBossThread) end
    if energyBossThread  then task.cancel(energyBossThread)  end
    deadeyeBossThread = task.spawn(deadeyeBossLoop)
    energyBossThread  = task.spawn(energyBossLoop)

    local removalConn
    removalConn = bossInstance.AncestryChanged:Connect(function()
        if bossInstance.Parent then return end
        removalConn:Disconnect()
        if currentBoss ~= bossInstance then return end
        currentBoss = nil
        if deadeyeBossThread then task.cancel(deadeyeBossThread) end
        if energyBossThread  then task.cancel(energyBossThread)  end
        deadeyeBossThread = nil
        energyBossThread  = nil

        -- UI: revert back to night status
        titleLabel.Text = "AUTO KITS"
        setStatus(loopsActive and "NIGHT" or "DAY")
        print("[Boss] Boss gone – energy loops stopped")
    end)
end

local function startBossMonitoring()
    if bossConnection then return end
    task.spawn(function()
        local ok, zombies = pcall(function()
            return Workspace:WaitForChild("Zombies", 30)
        end)
        if not ok or not zombies then
            warn("[Boss] Zombies folder not found within 30s")
            return
        end
        -- Check for a boss that already exists
        local existing = zombies:FindFirstChild("Boss")
        if existing then onBossAdded(existing) end
        bossConnection = zombies.ChildAdded:Connect(onBossAdded)
    end)
end

local function stopBossMonitoring()
    if bossConnection then
        bossConnection:Disconnect()
        bossConnection = nil
    end
    if deadeyeBossThread then task.cancel(deadeyeBossThread) end
    if energyBossThread  then task.cancel(energyBossThread)  end
    deadeyeBossThread = nil
    energyBossThread  = nil
    currentBoss = nil
end

-- ========== MAIN NIGHT LOOPS ==========
local function boosterLoop()
    while mainRunning do
        useConsumableIfOwned("Booster Kit")
        task.wait(30)
    end
end

local function bandageLoop()
    while mainRunning do
        useConsumableIfOwned("Bandage")
        task.wait(20)
    end
end

local function physicallyStartLoops()
    if loopsActive then return end
    loopsActive = true
    mainRunning = true
    boosterThread = task.spawn(boosterLoop)
    bandageThread = task.spawn(bandageLoop)
    startBossMonitoring()
    useConsumableIfOwned("Deadeye Drink")  -- one-time fire at night start
    setStatus("NIGHT")
    print("[System] Night loops started (Booster 30s | Bandage 20s | Deadeye once at start + boss loop)")
end

local function physicallyStopLoops()
    if not loopsActive then return end
    loopsActive = false
    mainRunning = false
    if boosterThread then task.cancel(boosterThread) end
    if bandageThread then task.cancel(bandageThread) end
    stopBossMonitoring()
    boosterThread   = nil
    bandageThread   = nil
    titleLabel.Text = "AUTO KITS"
    setStatus(masterEnabled and "DAY" or "OFF")
    print("[System] Loops stopped")
end

local function updateLoopsBasedOnTime()
    if masterEnabled and isNightTime() then
        physicallyStartLoops()
    else
        physicallyStopLoops()
    end
end

-- ========== TOGGLE ==========
function toggleMasterEnable()
    if toggleDebounce then return end
    toggleDebounce = true
    task.delay(0.4, function() toggleDebounce = false end)

    masterEnabled = not masterEnabled
    if masterEnabled then
        textLabel.Text = "DEACTIVATE"
        updateIndicator(true)
        animateBorderColor(COL_STROKE_ON)
        TweenService:Create(actionBg, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {
            BackgroundColor3 = Color3.fromRGB(14, 28, 22)
        }):Play()
        setStatus(isNightTime() and "NIGHT" or "DAY")
        print("[Master] Enabled")
        updateLoopsBasedOnTime()
    else
        textLabel.Text = "ACTIVATE"
        updateIndicator(false)
        animateBorderColor(COL_STROKE_OFF)
        TweenService:Create(actionBg, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {
            BackgroundColor3 = COL_ACTION_BG
        }):Play()
        physicallyStopLoops()
        setStatus("OFF")
        print("[Master] Disabled")
    end
end

-- ========== TIME MONITOR (1s tick) ==========
task.spawn(function()
    while true do
        task.wait(1)
        if not masterEnabled then continue end
        local wasNight = loopsActive
        updateLoopsBasedOnTime()
        if not wasNight and loopsActive then
            print("[Time] Night started – loops activated")
        elseif wasNight and not loopsActive then
            print("[Time] Day started – loops paused")
        end
    end
end)

