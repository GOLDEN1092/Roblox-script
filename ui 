-- ========== TIME DETECTION ==========
local function getCurrentHour()
    -- Scan all TextLabels in PlayerGui for a HH:MM pattern
    local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
    if not playerGui then return nil end
    for _, child in ipairs(playerGui:GetDescendants()) do
        if child:IsA("TextLabel") then
            local h = tonumber(child.Text:match("^(%d%d):%d%d$"))
            if h and h >= 0 and h <= 23 then
                return h
            end
        end
    end
    return nil
end

local function isNightTime()
    local hour = getCurrentHour()
    if hour == nil then return false end
    return hour >= 18 or hour < 6
end

