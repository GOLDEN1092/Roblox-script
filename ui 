RunService.Heartbeat:Connect(function()
    if isRefilling then return end
    if (tick() - lastRefillTime) < REFILL_COOLDOWN then return end
    if not isAmmoLow() then return end

    local char = getCharacter()
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return end

    for _, boxModel in ipairs(ammoBoxes) do
        if boxModel and boxModel.Parent then
            local dist = (root.Position - boxModel:GetPivot().Position).Magnitude
            if dist <= PROXIMITY_RANGE then
                isRefilling = true
                setAmmoStatus(true)

                local ok, err = pcall(pressF)
                if not ok then warn("[Ammo] pressF error:", err) end

                lastRefillTime = tick()
                local cur = getCurrentAmmo()
                print(string.format("[Ammo] Refilled near %s | %d/%d (%.0f%%)",
                    boxModel.Name, cur, maxAmmo,
                    maxAmmo > 0 and (cur / maxAmmo) * 100 or 0))

                task.wait(0.5)
                isRefilling = false
                setAmmoStatus(false)
                return
            end
        end
    end
end)

-- ── Ammo box registry ────────────────────────────────────────────────────────
local function registerBox(boxModel)
    for _, b in ipairs(ammoBoxes) do
        if b == boxModel then return end
    end
    table.insert(ammoBoxes, boxModel)
    print("[Ammo] Registered:", boxModel.Name)
end

local function unregisterBox(boxModel)
    for i, b in ipairs(ammoBoxes) do
        if b == boxModel then
            table.remove(ammoBoxes, i)
            return
        end
    end
end

