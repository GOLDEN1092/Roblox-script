-- Ammo source: tool.CurrentValues.Ammo (IntValue, lives in character while equipped)
local currentAmmoValue = nil
local maxAmmo          = 0

local function getCurrentAmmo()
    if currentAmmoValue then return currentAmmoValue.Value end
    return 0
end

local function isAmmoLow()
    if maxAmmo == 0 or currentAmmoValue == nil then return false end
    return (getCurrentAmmo() / maxAmmo) <= AMMO_THRESHOLD
end

-- Hook equipped tool's CurrentValues.Ammo directly
local function hookToolAmmo(tool)
    if not tool then
        currentAmmoValue = nil; maxAmmo = 0; return
    end
    local cv = tool:FindFirstChild("CurrentValues")
        or tool:FindFirstChild("CurrentValues", true)
    if not cv then
        warn("[Ammo] No CurrentValues in:", tool.Name)
        currentAmmoValue = nil; maxAmmo = 0; return
    end
    local ammoVal = cv:FindFirstChild("Ammo")
    if not ammoVal then
        warn("[Ammo] No Ammo IntValue for:", tool.Name)
        currentAmmoValue = nil; maxAmmo = 0; return
    end
    currentAmmoValue = ammoVal
    maxAmmo = ammoVal.Value
    print(string.format("[Ammo] Hooked %s | Max: %d | Threshold: ≤%d (%.0f%%)",
        tool.Name, maxAmmo, math.floor(maxAmmo * AMMO_THRESHOLD), AMMO_THRESHOLD * 100))
end

-- Watch character for equip/unequip
local function watchCharacterTools(char)
    if not char then return end
    local equipped = char:FindFirstChildOfClass("Tool")
    if equipped then hookToolAmmo(equipped) end
    char.ChildAdded:Connect(function(child)
        if child:IsA("Tool") then hookToolAmmo(child) end
    end)
    char.ChildRemoved:Connect(function(child)
        if child:IsA("Tool") then
            task.delay(0.1, function()
                hookToolAmmo(char:FindFirstChildOfClass("Tool"))
            end)
        end
    end)
end

local function onCharacterSpawned(char)
    currentAmmoValue = nil; maxAmmo = 0
    task.wait(1)
    watchCharacterTools(char)
end

if LocalPlayer.Character then
    task.spawn(onCharacterSpawned, LocalPlayer.Character)
end
