button.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
        dragStartPos = input.Position
        buttonStartPos = button.Position
    end
end)

button.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement then
        if dragStartPos and not dragging then
            local delta = input.Position - dragStartPos
            if math.abs(delta.X) > 5 or math.abs(delta.Y) > 5 then
                dragging = true
            end
        end
        if dragging and buttonStartPos then
            local delta = input.Position - dragStartPos
            button.Position = UDim2.new(
                buttonStartPos.X.Scale,
                buttonStartPos.X.Offset + delta.X,
                buttonStartPos.Y.Scale,
                buttonStartPos.Y.Offset + delta.Y
            )
        end
    end
end)

button.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
        if not dragging then
            -- Only toggle if the click/tap lands inside the action pill
            local pos = input.Position
            local ap = actionBg.AbsolutePosition
            local as = actionBg.AbsoluteSize
            if pos.X >= ap.X and pos.X <= ap.X + as.X and
               pos.Y >= ap.Y and pos.Y <= ap.Y + as.Y then
                toggleMasterEnable()
            end
        end
        dragging = false
        dragStartPos = nil
        buttonStartPos = nil
    end
end)

-- ========== REMOTE CACHING ==========
-- Cache the remote once at startup instead of fetching it on every use
local useConsumableRemote = nil
local remoteReady = false

local function tryInitRemote()
    local ok, result = pcall(function()
        local remoteFuncs = ReplicatedStorage:WaitForChild("RemoteFunctions", 20)
        return remoteFuncs:WaitForChild("UseConsumable", 20)
    end)
    if ok and result then
        useConsumableRemote = result
        remoteReady = true
        print("[Remote] UseConsumable cached successfully")
    else
        warn("[Remote] Could not find UseConsumable – will retry in 10s")
        task.delay(10, tryInitRemote)
    end
end
task.spawn(tryInitRemote)

-- ========== COOLDOWN SYSTEM ==========
-- Per-consumable cooldowns (seconds) – prevents double-firing if loops overlap
local COOLDOWNS = {
    ["Booster Kit"] = 30,
    ["Bandage"]     = 20,
    ["Energy Drink"] = 8,
}
local lastUsed = {}

local function canUse(itemName)
    local cd = COOLDOWNS[itemName] or 0
    local last = lastUsed[itemName]
    if not last then return true end
    return (tick() - last) >= cd
end

-- ========== CONSUMABLE AVAILABILITY ==========
local function hasConsumable(itemName)
    local backgear = LocalPlayer:FindFirstChild("Backgear")
    if not backgear then return false end
    return backgear:FindFirstChild(itemName) ~= nil
end

local function useConsumableIfOwned(itemName)
    if not remoteReady then
        warn("[Consumable] Remote not ready yet, skipping:", itemName)
        return false
    end
    if not hasConsumable(itemName) then return false end
    if not canUse(itemName) then return false end  -- cooldown guard

    lastUsed[itemName] = tick()  -- stamp before call to block overlap

    local success, err = pcall(function()
        useConsumableRemote:InvokeServer(itemName, LocalPlayer)
    end)
    if not success then
        warn("[Consumable] Failed to use", itemName, ":", err)
        lastUsed[itemName] = nil  -- refund cooldown on failure
        return false
    end
    print("[Consumable] Used:", itemName)
    return true
end

